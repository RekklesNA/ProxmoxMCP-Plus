{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/guidelines/*.md"
  ],
  "mcp": {
    "proxmox-mcp-plus": {
      "type": "local",
      "command": ["sh", "-c", ". ./proxmox-mcp.env && uvx --from git+https://github.com/NewsRx/ProxmoxMCP-Plus.git proxmox-mcp"],
      "enabled": true
    }
  }
}